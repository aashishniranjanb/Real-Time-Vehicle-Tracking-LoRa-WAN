# =========================================================
# LORAWAN VEHICLE TRACKING - BACKEND CONFIGURATION
# =========================================================
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control!
# =========================================================

# ---------------------------------------------------------
# TTN (The Things Network) MQTT Settings
# ---------------------------------------------------------

# MQTT Broker URL (depends on your TTN cluster)
# EU: eu1.cloud.thethings.network
# US: nam1.cloud.thethings.network
# AU: au1.cloud.thethings.network
TTN_MQTT_BROKER=eu1.cloud.thethings.network
TTN_MQTT_PORT=1883

# Your TTN Application ID
# Find this in TTN Console → Applications → Your App
TTN_APP_ID=your-ttn-app-id

# TTN API Key with MQTT access
# Generate in TTN Console → Applications → API Keys
# Required rights: Read application traffic (uplinks and downlinks)
TTN_API_KEY=NNSXS.your-api-key-here

# ---------------------------------------------------------
# Firebase Configuration (Optional)
# ---------------------------------------------------------

# Path to Firebase service account JSON file
FIREBASE_CREDENTIALS=path/to/firebase-credentials.json

# Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project

# ---------------------------------------------------------
# Dashboard Settings (Optional)
# ---------------------------------------------------------

# Dashboard server port
DASHBOARD_PORT=5000

# Enable debug mode
DEBUG=false
